# Exclude Node Modules
# Let Docker install them cleanly within the Linux container OS to avoid binary mismatches.
node_modules
frontend/node_modules
backend/node_modules
automation/node_modules

# Exclude Git History
.git
.github
.gitignore

# Exclude Editor Configurations
.vscode
.idea
.DS_Store

# Exclude local environment variables
# Production configuration comes entirely from Render environment variables.
.env
.env.*

# Exclude Documentation
# Improves build cache hit rates by ignoring text changes
README.md
DEPLOYMENT_GUIDE.md
DOCKER_MIGRATION_PLAN.md
TECHNICAL_ARCHITECTURE.md
PLAYWRIGHT_FRAMEWORK_ARCHITECTURE.md
DEPLOYMENT_CHANGES.md

# Exclude Frontend Code completely
# Vercel handles the frontend. Including it in the backend image wastes space.
frontend/

# Exclude Artifacts & Reports
# These are dynamically generated and belong strictly on the persistent disk.
backend/uploads
automation/playwright-report
automation/test-results
test-results/
playwright-report/
reports
screenshots
videos
traces

# Exclude Logs and Caches
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
coverage
tmp
cache
dist
.output
.npm
npm-cache
Thumbs.db
docker-compose.override.yml
