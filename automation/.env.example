# ─────────────────────────────────────────────────────────────────────────────
# automation/.env.example
#
# Local development configuration for running Playwright tests directly
# (i.e., without the backend dashboard: `npx playwright test`).
#
# Copy this file to `automation/.env` and fill in your values.
# When tests are triggered via the dashboard, the backend injects these vars
# automatically — the .env file is only needed for local direct runs.
#
# DO NOT commit automation/.env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Base URL ────────────────────────────────────────────────────────────────
# Selects the environment to test against.
# QA:         https://qa.cipherschools.com
# Production: https://www.cipherschools.com
BASE_URL=https://qa.cipherschools.com

# ─── Credentials ─────────────────────────────────────────────────────────────
TEST_EMAIL=your-test-user@example.com
TEST_PASSWORD=your-test-password

# ─── Test User Data ──────────────────────────────────────────────────────────
# Values specific to the TEST_EMAIL account used in assertions.
TEST_DISPLAY_NAME=Your Test User Name

# ─── Timeouts (milliseconds) ─────────────────────────────────────────────────
TEST_TIMEOUT=80000
NAV_TIMEOUT=60000
ACTION_TIMEOUT=20000
PAGE_WAIT_TIMEOUT=1000

# ─── Browser / Artifact Settings ─────────────────────────────────────────────
# trace:      off | on | on-first-retry | on-all-retries
# video:      off | on | on-first-retry | retain-on-failure
# screenshot: off | on | only-on-failure
TRACE=on-first-retry
VIDEO=off
SCREENSHOT=on
SLOW_MO=0
# LOCALE=en-US
# VIEWPORT={"width":1280,"height":720}

# ─── Output Paths ────────────────────────────────────────────────────────────
OUTPUT_DIR=./test-results
REPORT_DIR=./playwright-report

# ─── Parallelism ─────────────────────────────────────────────────────────────
RETRIES=0
# WORKERS=2
