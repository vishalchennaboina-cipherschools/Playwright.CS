# ─────────────────────────────────────────────────
# Playwright Automation Backend — Environment Config
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────

# ─── Server ──────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# ─── Database ────────────────────────────────────
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/

# CORS — comma-separated origins allowed by the dashboard
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# Playwright framework path (absolute or relative to backend/)
PLAYWRIGHT_PROJECT_PATH=../automation

# Logging
LOG_LEVEL=debug
LOG_DIR=uploads/logs

# Uploads / artifact storage root
UPLOADS_DIR=uploads

# ─── Test Credentials ────────────────────────────
# Injected into every Playwright child process as TEST_EMAIL / TEST_PASSWORD.
# NEVER hardcode credentials in test files — configure them here only.
TEST_EMAIL=your-test-user@example.com
TEST_PASSWORD=your-test-password

# ─── Test User Data ──────────────────────────────
# Account-specific values tied to the TEST_EMAIL account.
# Used in URL assertions and heading checks.
TEST_DISPLAY_NAME=Your Test User Name
TEST_BATCH_SLUG=your-batch-slug
TEST_CONTENT_ID=your-encoded-content-id

# ─── Timeouts (milliseconds) ─────────────────────
TEST_TIMEOUT=80000
NAV_TIMEOUT=60000
ACTION_TIMEOUT=20000
PAGE_WAIT_TIMEOUT=1000

# ─── Browser / Artifact Settings ─────────────────
# trace:      off | on | on-first-retry | on-all-retries
# video:      off | on | on-first-retry | retain-on-failure
# screenshot: off | on | only-on-failure
TRACE=on-first-retry
VIDEO=off
SCREENSHOT=only-on-failure
SLOW_MO=0

# ─── Output Paths ────────────────────────────────
# Override these to store artifacts in a custom location.
OUTPUT_DIR=/tmp/test-results
REPORT_DIR=/tmp/playwright-report

# ─── Parallelism ─────────────────────────────────
RETRIES=0

# ─── Auth (future — leave blank to disable) ──────
# JWT_SECRET=
# JWT_EXPIRY=24h

# ─── Notifications (future) ──────────────────────
# SLACK_WEBHOOK_URL=
# EMAIL_RECIPIENT=

# ─────────────────────────────────────────────────
# Production (Render) — Reference Values
# Set in the Render dashboard or render.yaml, NOT here.
# ─────────────────────────────────────────────────
# NODE_ENV=production
# PORT=10000
# HOST=0.0.0.0
# CORS_ORIGIN=https://your-app-name.vercel.app
# LOG_LEVEL=info
# TEST_EMAIL=prod-test-user@example.com
# TEST_PASSWORD=prod-test-password
