# ─────────────────────────────────────────────────
# Playwright Automation Backend — Environment Config
# Copy to .env and fill in your values.
# ─────────────────────────────────────────────────

# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# CORS — comma-separated origins allowed by the dashboard
CORS_ORIGIN=http://localhost:8080,http://localhost:5173

# Playwright framework path (absolute or relative to backend/)
PLAYWRIGHT_PROJECT_PATH=../automation

# Logging
LOG_LEVEL=debug
LOG_DIR=uploads/logs

# Uploads / artifact storage root
UPLOADS_DIR=uploads

# Auth (future — leave blank to disable)
# JWT_SECRET=
# JWT_EXPIRY=24h

# Notifications (future)
# SLACK_WEBHOOK_URL=
# EMAIL_RECIPIENT=

# ─────────────────────────────────────────────────
# Production (Render) — Reference Values
# These are set in the Render dashboard or render.yaml,
# NOT in this .env file.
# ─────────────────────────────────────────────────
# NODE_ENV=production
# PORT=10000
# HOST=0.0.0.0
# CORS_ORIGIN=https://your-app-name.vercel.app
# LOG_LEVEL=info
